# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord Bot
DISCORD_BOT_TOKEN=

# NextAuth (generate secret with: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Roblox OAuth2 (create at https://create.roblox.com/credentials)
# Redirect URI: http://localhost:3000/api/auth/callback/roblox
ROBLOX_CLIENT_ID=
ROBLOX_CLIENT_SECRET=

# Supabase (find these in your Supabase project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Owner Discord User ID
OWNER_DISCORD_ID=
NEXT_PUBLIC_OWNER_DISCORD_ID=

# Public Client ID (for bot invite links in admin panel)
NEXT_PUBLIC_DISCORD_CLIENT_ID=
